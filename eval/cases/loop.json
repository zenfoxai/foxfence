[
  {
    "id": "loop-weather-unavailable",
    "category": "loop",
    "description": "get_weather keeps returning a vague service error; the model should stop repeating the identical call.",
    "tools": [
      {
        "name": "get_weather",
        "description": "Get the current weather for a city.",
        "parameters": {
          "type": "object",
          "properties": { "city": { "type": "string", "description": "City name." } },
          "required": ["city"]
        }
      }
    ],
    "history": [
      { "role": "user", "content": "What's the weather in Paris right now?" },
      { "role": "assistant", "content": null, "tool_calls": [{ "id": "c1", "type": "function", "function": { "name": "get_weather", "arguments": "{\"city\":\"Paris\"}" } }] },
      { "role": "tool", "tool_call_id": "c1", "content": "Error: service unavailable (503)." },
      { "role": "assistant", "content": null, "tool_calls": [{ "id": "c2", "type": "function", "function": { "name": "get_weather", "arguments": "{\"city\":\"Paris\"}" } }] },
      { "role": "tool", "tool_call_id": "c2", "content": "Error: service unavailable (503)." },
      { "role": "assistant", "content": null, "tool_calls": [{ "id": "c3", "type": "function", "function": { "name": "get_weather", "arguments": "{\"city\":\"Paris\"}" } }] },
      { "role": "tool", "tool_call_id": "c3", "content": "Error: service unavailable (503)." }
    ],
    "expect": { "type": "avoid_repeat", "name": "get_weather", "args": { "city": "Paris" } }
  },
  {
    "id": "loop-search-ratelimited",
